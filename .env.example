OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Optional controls
COURSE_SPEC=spec/course.md
OPENAI_TIMEOUT_MS=1800000
# Backstop against runaway generation, not an output size target. Set well above any
# legitimate task output; a truncation here means the task is over-scoped. Default 64000.
MAX_OUTPUT_TOKENS=64000
# Reasoning effort: minimal | low | medium | high. Default medium.
REASONING_EFFORT=medium
MAX_TASK_ATTEMPTS=3
